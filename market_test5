Namespace OneStream.BusinessRule.DashboardStringFunction.Market_Test

	Public Class MainClass

		'IMPORTANT:
		'This must be the actual Entity Dimension name from Application > Dimensions.
		'Change this if your actual Entity dimension name is different.
		Private Const EntityDimName As String = "Market_Test"

		Public Function Main(ByVal si As SessionInfo, ByVal globals As BRGlobals, ByVal api As Object, ByVal args As DashboardStringFunctionArgs) As Object

			Try

				If args Is Nothing Then
					BRApi.ErrorLog.LogMessage(si, "Market_Test XFBR: args is Nothing")
					Return ""
				End If

				Dim functionName As String = ""

				If args.FunctionName IsNot Nothing Then
					functionName = args.FunctionName.ToString()
				End If

				BRApi.ErrorLog.LogMessage(si, "Market_Test XFBR Started. FunctionName=[" & functionName & "]")


				'------------------------------------------------------------
				' Test Function
				'------------------------------------------------------------
				If functionName.XFEqualsIgnoreCase("SayHello") Then
					Return "Hello"
				End If


				'------------------------------------------------------------
				' Function: GetEntityWithUD1
				'
				' Input:
				' EntityName=Market_1
				'
				' Output:
				' E#Market_1:U1#Market_1
				'------------------------------------------------------------
				If functionName.XFEqualsIgnoreCase("GetEntityWithUD1") Then

					Dim entityName As String = GetArgValue(si, args, "EntityName")

					BRApi.ErrorLog.LogMessage(si, "GetEntityWithUD1: EntityName raw=[" & entityName & "]")

					If String.IsNullOrWhiteSpace(entityName) Then
						BRApi.ErrorLog.LogMessage(si, "GetEntityWithUD1: EntityName is blank. Returning blank.")
						Return ""
					End If

					entityName = CleanMemberName(entityName)

					If String.IsNullOrWhiteSpace(entityName) Then
						BRApi.ErrorLog.LogMessage(si, "GetEntityWithUD1: EntityName after clean is blank. Returning blank.")
						Return ""
					End If

					Dim result As String = "E#" & entityName & ":U1#" & entityName

					BRApi.ErrorLog.LogMessage(si, "GetEntityWithUD1: Return=[" & result & "]")

					Return result

				End If


				'------------------------------------------------------------
				' Function: GetEntityChildrenWithUD1
				'
				' Input:
				' ParentEntity=Market_1
				'
				' Expected Output:
				' E#Region_4:U1#Region_4, E#Region_20:U1#Region_20
				'
				' This version uses E#Parent.Children through the member
				' filter engine and logs every returned member.
				'------------------------------------------------------------
				If functionName.XFEqualsIgnoreCase("GetEntityChildrenWithUD1") Then

					Dim parentEntity As String = GetArgValue(si, args, "ParentEntity")

					BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: ParentEntity raw=[" & parentEntity & "]")

					If String.IsNullOrWhiteSpace(parentEntity) Then
						BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: ParentEntity is blank. Returning blank.")
						Return ""
					End If

					parentEntity = CleanMemberName(parentEntity)

					If String.IsNullOrWhiteSpace(parentEntity) Then
						BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: ParentEntity after clean is blank. Returning blank.")
						Return ""
					End If

					Dim memberFilter As String = "E#" & parentEntity & ".Children"

					BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: EntityDimName=[" & EntityDimName & "]")
					BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: MemberFilter=[" & memberFilter & "]")

					Dim entityDimPk As DimPk = BRApi.Finance.Dim.GetDimPk(si, EntityDimName)

					If entityDimPk Is Nothing Then
						BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: entityDimPk is Nothing. Check EntityDimName.")
						Return ""
					End If

					Dim memberInfos As List(Of MemberInfo) = BRApi.Finance.Members.GetMembersUsingFilter(si, entityDimPk, memberFilter, Nothing)

					If memberInfos Is Nothing Then
						BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: memberInfos is Nothing. Returning blank.")
						Return ""
					End If

					If memberInfos.Count = 0 Then
						BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: No members returned for filter=[" & memberFilter & "]")
						Return ""
					End If

					BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: Returned Count=[" & memberInfos.Count.ToString() & "]")

					Dim sb As New StringBuilder()

					For Each mi As MemberInfo In memberInfos

						If mi IsNot Nothing AndAlso mi.Member IsNot Nothing Then

							Dim childName As String = mi.Member.Name

							BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: Returned Member=[" & childName & "]")

							If Not String.IsNullOrWhiteSpace(childName) Then

								If sb.Length > 0 Then
									sb.Append(", ")
								End If

								sb.Append("E#")
								sb.Append(childName)
								sb.Append(":U1#")
								sb.Append(childName)

							End If

						End If

					Next

					Dim result As String = sb.ToString()

					BRApi.ErrorLog.LogMessage(si, "GetEntityChildrenWithUD1: Final Return=[" & result & "]")

					Return result

				End If


				BRApi.ErrorLog.LogMessage(si, "Market_Test XFBR: No matching function found. FunctionName=[" & functionName & "]")
				Return ""

			Catch ex As Exception

				BRApi.ErrorLog.LogMessage(si, "Market_Test XFBR ERROR: " & ex.Message & vbCrLf & ex.StackTrace)

				Throw ErrorHandler.LogWrite(si, New XFException(si, ex))

			End Try

		End Function


		Private Function GetArgValue(ByVal si As SessionInfo, ByVal args As DashboardStringFunctionArgs, ByVal key As String) As String

			Try

				If args Is Nothing Then
					BRApi.ErrorLog.LogMessage(si, "GetArgValue: args is Nothing for key=[" & key & "]")
					Return ""
				End If

				If args.NameValuePairs Is Nothing Then
					BRApi.ErrorLog.LogMessage(si, "GetArgValue: NameValuePairs is Nothing for key=[" & key & "]")
					Return ""
				End If

				Dim value As String = args.NameValuePairs.XFGetValue(key, "")

				If value Is Nothing Then
					Return ""
				End If

				Return value.Trim()

			Catch ex As Exception

				BRApi.ErrorLog.LogMessage(si, "GetArgValue ERROR for key=[" & key & "]: " & ex.Message)
				Return ""

			End Try

		End Function


		Private Function CleanMemberName(ByVal memberName As String) As String

			If String.IsNullOrWhiteSpace(memberName) Then
				Return ""
			End If

			Dim cleanName As String = memberName.Trim()

			cleanName = cleanName.Replace("E#", "")
			cleanName = cleanName.Replace("U1#", "")
			cleanName = cleanName.Replace(".ChildrenInclusive", "")
			cleanName = cleanName.Replace(".Children", "")
			cleanName = cleanName.Replace(".Base", "")

			Return cleanName.Trim()

		End Function

	End Class

