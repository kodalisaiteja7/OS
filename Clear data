Namespace OneStream.BusinessRule.Finance.BPA_ClearData_AcctFilter
	Public Class MainClass
		Public Function Main(ByVal si As SessionInfo, ByVal globals As BRGlobals, ByVal api As FinanceRulesApi, ByVal args As FinanceRulesArgs) As Object
			Try
				Dim strUD1 As String = api.Pov.UD1.Name
				Dim strUD3 As String = api.Pov.UD3.Name

				'Get Account Filter
				Dim objDictionary As Dictionary(Of String, String) = args.CustomCalculateArgs.NameValuePairs
				Dim AcctFilter As String = String.Empty
			    If (objdictionary.TryGetValue("AcctFilter", AcctFilter)) Then
			    End If
				
				'Clears ALL data (imported & user entered)
				api.Data.ClearCalculatedData(True,True,True,True,AcctFilter,"F#None","O#BEforeAdj.Base","I#None","U1#" & strUD1 & ".Base",,"U3#" & strUD3 & ".Base")
				api.Data.Calculate("F#None:IC#None = RemoveNoData(F#None:IC#None) * 0",AcctFilter,,,,"U1#" & strUD1 & ".Base",,"U3#" & strUD3 & ".Base")
				
				Return Nothing
			Catch ex As Exception
				Throw ErrorHandler.LogWrite(si, New XFException(si, ex))
			End Try
		End Function
	End Class
