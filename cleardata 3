Namespace OneStream.BusinessRule.Finance.MM_ClearFData

	Public Class MainClass

		Public Function Main(ByVal si As SessionInfo, ByVal globals As BRGlobals, ByVal api As FinanceRulesApi, ByVal args As FinanceRulesArgs) As Object

			Try

				Select Case api.FunctionType

					Case Is = FinanceFunctionType.CustomCalculate

						Dim functionName As String = args.CustomCalculateArgs.FunctionName

						Select Case functionName

							Case Is = "ClearFlowData"

								ClearFlowData(si, globals, api, args)

						End Select

				End Select

				Return Nothing

			Catch ex As Exception
				Throw ErrorHandler.LogWrite(si, New XFException(si, ex))
			End Try

		End Function


		Private Sub ClearFlowData(ByVal si As SessionInfo, ByVal globals As BRGlobals, ByVal api As FinanceRulesApi, ByVal args As FinanceRulesArgs)

			Try

				BRApi.ErrorLog.LogMessage(si, "MM_ClearFData - ClearFlowData started.")

				BRApi.ErrorLog.LogMessage(si, "Cube: " & api.Pov.Cube.Name)
				BRApi.ErrorLog.LogMessage(si, "Entity: " & api.Pov.Entity.Name)
				BRApi.ErrorLog.LogMessage(si, "Scenario: " & api.Pov.Scenario.Name)
				BRApi.ErrorLog.LogMessage(si, "Time: " & api.Pov.Time.Name)
				BRApi.ErrorLog.LogMessage(si, "Cons: " & api.Pov.Cons.Name)

				'Clear Allocation Manager calculated/durable calculated results
				'Targeting only Flow Direct and Direct_Offset
				api.Data.ClearCalculatedData( _
					True, _
					True, _
					True, _
					True, _
					Nothing, _
					"F#Direct,F#Direct_Offset", _
					Nothing, _
					Nothing, _
					Nothing, _
					Nothing, _
					Nothing, _
					Nothing, _
					Nothing, _
					Nothing, _
					Nothing)

				BRApi.ErrorLog.LogMessage(si, "MM_ClearFData - Cleared calculated/durable data for F#Direct and F#Direct_Offset.")

			Catch ex As Exception
				Throw ErrorHandler.LogWrite(si, New XFException(si, ex))
			End Try

		End Sub

	End Class

End Namespace
