Namespace OneStream.BusinessRule.Extender.Clear_Import_Direct_Flows

	Public Class MainClass

		Public Function Main(ByVal si As SessionInfo, ByVal globals As BRGlobals, ByVal api As Object, ByVal args As ExtenderArgs) As Object

			Try

				Select Case args.FunctionType

					Case Is = ExtenderFunctionType.ExecuteDataMgmtBusinessRuleStep

						ClearImportDirectFlows(si, globals, api, args)

				End Select

				Return Nothing

			Catch ex As Exception
				Throw ErrorHandler.LogWrite(si, New XFException(si, ex))
			End Try

		End Function


		Private Sub ClearImportDirectFlows(ByVal si As SessionInfo, ByVal globals As BRGlobals, ByVal api As Object, ByVal args As ExtenderArgs)

			Try

				'Clears loaded/input data from Origin Import for Flow Direct
				api.Data.Calculate("O#Import:F#Direct = 0 * RemoveZeros(O#Import:F#Direct)", True)

				'Clears loaded/input data from Origin Import for Flow Direct_Offset
				api.Data.Calculate("O#Import:F#Direct_Offset = 0 * RemoveZeros(O#Import:F#Direct_Offset)", True)

				BRApi.ErrorLog.LogMessage(si, "Cleared O#Import data for F#Direct and F#Direct_Offset.")

			Catch ex As Exception
				Throw ErrorHandler.LogWrite(si, New XFException(si, ex))
			End Try

		End Sub

	End Class

End Namespace
